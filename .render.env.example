DB_PROVIDER=postgres
SUPABASE_DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-eu-west-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_SSL=true
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<service-role-key>
SUPABASE_STORAGE_BUCKET=materials
SUPABASE_STORAGE_FOLDER=materials
SUPABASE_STORAGE_BUCKET_PUBLIC=true
SUPABASE_STORAGE_FILE_SIZE_LIMIT=104857600
MAX_UPLOAD_SIZE_BYTES=104857600
REQUIRE_PERSISTENT_STORAGE=true
JWT_SECRET=<strong-random-secret>
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=<set-a-strong-admin-password>
FRONTEND_URL=https://spiritualcenter.vercel.app
CORS_ORIGINS=https://spiritualcenter.vercel.app,https://spiritualcenter-git-main-solomon-adieles-projects.vercel.app,https://spiritualcenter-4jb20nhuo-solomon-adieles-projects.vercel.app
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
ALLOW_PLAINTEXT_RESET_TOKEN=true
