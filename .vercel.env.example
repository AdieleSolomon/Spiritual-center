# Vercel frontend environment variables
# Reference values for Vercel project settings.
# Add these in Vercel Project Settings -> Environment Variables

# Railway backend API base URL
NEXT_PUBLIC_API_BASE_URL=https://your-railway-backend.up.railway.app/api

# Google integrations (optional but recommended)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps?q=Center+of+Knowledge+and+Spiritual+Enrichment&output=embed
NEXT_PUBLIC_GOOGLE_MAPS_DIRECTIONS_URL=https://www.google.com/maps/search/?api=1&query=Center+of+Knowledge+and+Spiritual+Enrichment

# Optional
NEXT_PUBLIC_SITE_URL=https://spiritualcenter.vercel.app
