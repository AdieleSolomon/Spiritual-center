# Railway backend environment variables
# Copy to .railway.env for local reference or paste into Railway service variables.

NODE_ENV=production
# Fix for npm deprecated 'production' flag warning
NPM_CONFIG_PRODUCTION=false
NPM_CONFIG_OMIT=dev
DB_PROVIDER=postgres
DB_CONNECTION_LIMIT=10
POSTGRES_SSL=false

# Railway Postgres connection values
DATABASE_URL=postgresql://postgres:<password>@postgres.railway.internal:5432/railway
DATABASE_PUBLIC_URL=postgresql://postgres:<password>@<proxy-host>:<proxy-port>/railway
PGHOST=postgres.railway.internal
PGPORT=5432
PGUSER=postgres
PGPASSWORD=<password>
PGDATABASE=railway

# Frontend origins
FRONTEND_URL=https://spiritualcenter.vercel.app
CORS_ORIGINS=https://spiritualcenter.vercel.app,https://spiritualcenter-gfks6j5au-solomon-adieles-projects.vercel.app

# Security
JWT_SECRET=<strong-random-secret>
SUPER_ADMIN_EMAIL=admin@spiritualcenter.com
SUPER_ADMIN_PASSWORD=<set-a-strong-super-admin-password>

# Optional upload storage
# Leave these as false to use Railway's local /uploads fallback (not persistent across redeploys).
SUPABASE_STORAGE_ENABLED=false
REQUIRE_PERSISTENT_STORAGE=false
#
# For persistent production uploads, switch SUPABASE_STORAGE_ENABLED to true and provide:
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_<service-role-key>
# SUPABASE_STORAGE_BUCKET=materials
# # SUPABASE_STORAGE_ENABLED=true

PASSWORD_RESET_TOKEN_TTL_MINUTES=30
ALLOW_PLAINTEXT_RESET_TOKEN=true
